        for field_name in (
            "fixed_star_longitude_deg",
            "target_longitude_deg",
            "orb_deg",
            "max_orb_deg",
        ):
            if not isfinite(float(getattr(self, field_name))):
                raise ValueError(f"fixed star conjunction payload requires finite {field_name}")
        if self.orb_deg < 0.0:
