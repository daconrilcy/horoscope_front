    fixed_star_longitude_deg: float
    target_longitude_deg: float
    orb_deg: float
    max_orb_deg: float
    rule_code: str
    source: str

    def __post_init__(self) -> None:
        """Valide la provenance et les valeurs numeriques du contact."""
        for field_name in (
