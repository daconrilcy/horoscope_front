        for row in load_structural_reference_rows("houses"):
            number = int(row["number"])
            house = self.db.scalar(select(HouseModel).where(HouseModel.number == number))
            if house is None:
                self.db.add(HouseModel(number=number, name=str(row["name"])))
            else:
