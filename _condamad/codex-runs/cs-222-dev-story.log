"""Tests du calcul runtime des conjonctions d'etoiles fixes."""

from __future__ import annotations

import pytest

from app.domain.astrology.fixed_stars.contracts import (
    DEFAULT_FIXED_STAR_CONJUNCTION_MAX_ORB_DEG,
