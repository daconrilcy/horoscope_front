            }
            if synthesis is not None
            else None
        ),
    }


def _serialize_astral_points(
    points: Any, *, neutralize_house: bool = False
) -> list[dict[str, Any]]:
    """Projette les points astraux deja calcules dans le resultat natal."""
    if not isinstance(points, (list, tuple)):
