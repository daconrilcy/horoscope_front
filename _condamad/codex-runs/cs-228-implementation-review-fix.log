)
FORBIDDEN_IMPORT_PREFIXES = (
    "app.api",
    "app.infra",
    "app." + "infrastructure",
    "app.services",
    "sqlalchemy",
    "fastapi",
    "pydantic",
)
FORBIDDEN_CONDITION_CALCULATOR_CALLS = (
