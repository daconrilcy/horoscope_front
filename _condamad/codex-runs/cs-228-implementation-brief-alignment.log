    ) -> list[dict[str, object]]:
        """Produit des positions dont Mars conjoint Regulus."""
        del julian_day
        positions = []
        for index, planet_code in enumerate(planet_codes):
            longitude = 150.42 if planet_code == "mars" else float((index * 31) % 360)
            positions.append(
