    system_code: str = "modern"

    def __post_init__(self) -> None:
        """Valide les champs interpretatifs courts, sans texte narratif."""
        required_values = (
            self.aspect_code,
            self.default_valence,
            self.interpretive_valence,
            self.energy_type,
            self.system_code,
