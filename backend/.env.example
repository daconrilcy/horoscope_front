# Backend
PYTHONUNBUFFERED=1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# Database placeholders
POSTGRES_DB=horoscope
POSTGRES_USER=horoscope
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Cache placeholder
REDIS_PORT=6379

# App runtime
APP_ENV=development
DATABASE_URL=postgresql+psycopg://horoscope:change_me@localhost:5432/horoscope
# Prediction stack active by default in local/dev:
# ruleset 2.0.0 is seeded against reference version 2.0.0.
ACTIVE_REFERENCE_VERSION=2.0.0
RULESET_VERSION=2.0.0

# Required in production for POST /v1/reference-data/seed
REFERENCE_SEED_ADMIN_TOKEN=change_me

# JWT auth
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=15
JWT_REFRESH_MINUTES=10080
NATAL_GENERATION_TIMEOUT_SECONDS=150

# API credentials hashing (required in production)
API_CREDENTIALS_SECRET_KEY=change_me

# LLM & AI Engine
OPENAI_API_KEY=sk-xxxx
# Fallback model
OPENAI_MODEL_DEFAULT=gpt-4o-mini

# Granular OpenAI model configuration per prompt (Optional)
# Fallbacks to OPENAI_MODEL_DEFAULT if not set.
OPENAI_ENGINE_GUIDANCE_DAILY=gpt-4o-mini
OPENAI_ENGINE_GUIDANCE_WEEKLY=gpt-4o-mini
OPENAI_ENGINE_GUIDANCE_CONTEXTUAL=gpt-4o-mini
OPENAI_ENGINE_NATAL_INTERPRETATION=gpt-4o
OPENAI_ENGINE_NATAL_SHORT=gpt-4o-mini
OPENAI_ENGINE_CHAT=gpt-4o-mini
OPENAI_ENGINE_EVENT_GUIDANCE=gpt-4o
OPENAI_ENGINE_NATAL_PSY=gpt-4o
OPENAI_ENGINE_NATAL_SHADOW=gpt-4o
OPENAI_ENGINE_NATAL_WORK=gpt-4o
OPENAI_ENGINE_NATAL_JOY=gpt-4o
OPENAI_ENGINE_NATAL_RELATIONSHIP=gpt-4o
OPENAI_ENGINE_NATAL_COMMUNITY=gpt-4o
OPENAI_ENGINE_NATAL_VALUES=gpt-4o
OPENAI_ENGINE_NATAL_EVOLUTION=gpt-4o
OPENAI_ENGINE_SUPPORT=gpt-4o-mini

# Model overrides per use-case (Legacy support)
# Format: LLM_MODEL_OVERRIDE_{USE_CASE_KEY_UPPER}
# LLM_MODEL_OVERRIDE_NATAL_INTERPRETATION_SHORT=gpt-4o-mini
# LLM_MODEL_OVERRIDE_NATAL_INTERPRETATION=gpt-4o
# LLM_MODEL_OVERRIDE_CHAT=gpt-4o-mini

# Swiss Ephemeris (prod packaging)
SWISSEPH_ENABLED=false
SWISSEPH_PRO_MODE=false
# Offline timezone derivation (from lat/lon coordinates)
TIMEZONE_DERIVED_ENABLED=false
EPHEMERIS_PATH=
EPHEMERIS_PATH_VERSION=
EPHEMERIS_PATH_HASH=
# Comma-separated filenames required when SWISSEPH_PRO_MODE=true
EPHEMERIS_REQUIRED_FILES=seas_18.se1,semo_18.se1,sepl_18.se1,seas_24.se1,semo_24.se1,sepl_24.se1

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_PRICE_BASIC=price_xxxx
STRIPE_PRICE_PREMIUM=price_yyyy
# STRIPE_WEBHOOK_SECRET :
# - DEV (Stripe CLI) : whsec_xxxx (affiché par `stripe listen`)
# - PROD (Dashboard) : whsec_yyyy (depuis Dashboard Stripe > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:5173/settings/subscription
# Optionnel: ID de configuration spécifique pour le Customer Portal (bpc_...)
STRIPE_PORTAL_CONFIGURATION_ID=
STRIPE_TAX_ENABLED=false
STRIPE_TAX_ID_COLLECTION_ENABLED=false
STRIPE_CHECKOUT_BILLING_ADDRESS_COLLECTION=auto
