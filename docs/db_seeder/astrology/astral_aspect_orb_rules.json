{
  "name": "astral_aspect_orb_rules",
  "structure": {
    "table_role": "Specific orb override rules for natal and predictive aspect calculations. These rules refine the default orb defined in astral_aspect_definitions without moving observed orb values into reference tables.",
    "versioning": {
      "versioned": true,
      "version_column": "reference_version_id",
      "locked_by": "astral_reference_versions.is_locked"
    },
    "columns": {
      "id": "integer",
      "reference_version_id": "foreign_key:astral_reference_versions.id",
      "astral_system_id": "foreign_key:astral_systems.id",
      "aspect_id": "foreign_key:astral_aspects.id",
      "calculation_context": "enum:natal|transit_to_natal|sky_to_sky|progression_to_natal|any",
      "source_body_type": "enum:any|planet|luminary|personal_planet|social_planet|transpersonal_planet|angle|point",
      "source_planet_id": "nullable foreign_key:astral_planets.id",
      "source_point_code": "nullable string",
      "target_body_type": "enum:any|planet|luminary|personal_planet|social_planet|transpersonal_planet|angle|point",
      "target_planet_id": "nullable foreign_key:astral_planets.id",
      "target_point_code": "nullable string",
      "orb_deg": "float",
      "priority": "integer",
      "is_enabled": "boolean",
      "micro_note": "text|null"
    },
    "constraints": {
      "unique_key": [
        "reference_version_id",
        "astral_system_id",
        "aspect_id",
        "calculation_context",
        "source_body_type",
        "source_planet_id",
        "source_point_code",
        "target_body_type",
        "target_planet_id",
        "target_point_code"
      ],
      "checks": [
        "orb_deg > 0",
        "priority >= 0",
        "source_planet_id IS NULL OR source_body_type IN ('planet', 'luminary', 'personal_planet', 'social_planet', 'transpersonal_planet')",
        "target_planet_id IS NULL OR target_body_type IN ('planet', 'luminary', 'personal_planet', 'social_planet', 'transpersonal_planet')"
      ],
      "indexes": [
        [
          "reference_version_id",
          "astral_system_id",
          "aspect_id"
        ],
        [
          "calculation_context"
        ],
        [
          "priority"
        ]
      ]
    },
    "resolution_order": [
      {
        "level": 1,
        "rule": "Exact planet pair rule",
        "example": "sun + moon + opposition"
      },
      {
        "level": 2,
        "rule": "Specific planet to body-type rule",
        "example": "sun -> any luminary"
      },
      {
        "level": 3,
        "rule": "Luminary rule",
        "example": "any luminary involved"
      },
      {
        "level": 4,
        "rule": "Angle rule",
        "example": "aspect to asc or mc"
      },
      {
        "level": 5,
        "rule": "Planet class rule",
        "example": "transpersonal planet involved"
      },
      {
        "level": 6,
        "rule": "Fallback to astral_aspect_definitions.default_orb_deg"
      }
    ],
    "implementation_notes": [
      "The observed orb of an actual aspect must remain in runtime payloads such as AspectResult.orb and must not be persisted in this reference table.",
      "The fallback remains astral_aspect_definitions.default_orb_deg.",
      "astral_aspect_profiles.orb_multiplier should remain predictive/scoring-oriented and should not be used as a canonical natal orb definition.",
      "Rules should be resolved by local system before inherited parent, then by descending priority, then by specificity.",
      "For V1 runtime compatibility, only major aspects should be consumed by natal and transit calculators until the canonical major-aspect helper and EventDetector.ASPECTS_V1 are explicitly extended."
    ]
  },
