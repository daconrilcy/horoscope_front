{
  "name": "astral_chart_planet_dignity_results",
  "table_role": "Runtime audit table used to persist calculated dignity scores, detected conditions and explanatory breakdowns for each planet in a chart result.",
  "structure": {
    "chart_result_id": "integer, FK -> chart_results.id",
    "planet_id": "integer, FK -> astral_planets.id",
    "score_profile_id": "integer, FK -> astral_diginity_score_profiles.id",
    "astral_system_id": "integer, FK -> astral_systems.id",
    "reference_version_id": "integer, FK -> astral_reference_versions.id",
    "essential_score": "number",
    "accidental_score": "number",
    "total_score": "number",
    "functional_strength_score": "number",
    "expression_quality_score": "number",
    "intensity_score": "number",
    "essential_breakdown_json": "array",
    "accidental_breakdown_json": "array",
    "condition_summary_json": "object",
    "calculation_context_json": "object",
    "created_at": "datetime"
  },
  "constraints": {
    "unique": [
      [
        "chart_result_id",
        "planet_id",
        "score_profile_id",
        "reference_version_id"
      ]
    ]
  },
  "data": []
}
